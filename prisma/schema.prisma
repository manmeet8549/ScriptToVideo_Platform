// Prisma Schema — ScriptForge AI
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH MODELS (required by @auth/prisma-adapter)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// CORE APPLICATION MODELS
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  emailVerified DateTime?
  image        String?
  passwordHash       String?   // null for OAuth users
  role               Role          @default(USER)
  accountStatus      AccountStatus @default(ACTIVE)
  temporaryPassword  String?
  mustChangePassword Boolean       @default(false)
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  deletedBy          String?
  phoneNumber        String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  passwordChangedAt DateTime?

  editorProfile EditorProfile?

  // Relations
  accounts          Account[]
  sessions          Session[]
  projects          Project[]
  generationHistory GenerationHistory[]
  apiKeys           ApiKey[]
  providerKeys      ProviderKey[]
  settings          UserSettings?
  videos            Video[]
  socialAccounts    SocialAccount[]
  publishedVideos   PublishedVideo[]
  connectionsAsUser   EditorUserConnection[] @relation("UserConnections")
  connectionsAsEditor EditorUserConnection[] @relation("EditorConnections")
  notifications       Notification[]
  assignmentsAsUser   VideoAssignment[] @relation("UserAssignments")
  assignmentsAsEditor VideoAssignment[] @relation("EditorAssignments")
  approvalRequests    ApprovalRequest[]
  calendarEventsAsUser   CalendarEvent[] @relation("UserEvents")
  calendarEventsAsEditor CalendarEvent[] @relation("EditorEvents")

  // Credit System
  creditWallet        CreditWallet?
  creditTransactions  CreditTransaction[]

  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
}

model Project {
  id          String  @id @default(cuid())
  name        String
  prompt      String  @db.Text
  status      ProjectStatus @default(DRAFT)
  step        ProjectStep   @default(IDEA)

  // Generated content
  scriptText  String? @db.Text
  voiceAccent String?
  videoRatio  VideoRatio?
  videoUrl    String?
  duration    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  scripts           Script[]
  voices            Voice[]
  generationHistory GenerationHistory[]
  videos            Video[]
  publishedVideos   PublishedVideo[]

  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
}

model Script {
  id        String   @id @default(cuid())
  content   String   @db.Text
  version   Int      @default(1)
  tone      String?
  language  String   @default("en")

  createdAt DateTime @default(now())

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Voice {
  id       String  @id @default(cuid())
  accent   String
  audioUrl String?
  duration String?
  speed    Float?   @default(1.0)
  pitch    Int?     @default(0)
  emotion  String?  @default("Professional & Calm")

  createdAt DateTime @default(now())

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GenerationHistory {
  id       String             @id @default(cuid())
  type     GenerationType
  status   GenerationStatus   @default(PENDING)
  metadata Json?              // flexible JSON for provider responses, token counts, etc.

  createdAt DateTime @default(now())

  // Relations
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String    @unique    // bcrypt hash of the actual key
  keyPrefix String               // first 8 chars shown in UI e.g. "sk_live_"
  scopes    String[]  @default(["read", "write"])
  lastUsed  DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderKey {
  id        String   @id @default(cuid())
  provider  String   // "NVIDIA", "ELEVENLABS", "HEYGEN"
  value     String   // Encrypted API key value
  lastFour  String   // Last 4 characters (e.g. to show mask)
  prefix    String?  // Prefix (e.g., nvapi-, sk_)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([organizationId, provider])
}

model UserSettings {
  id              String   @id @default(cuid())
  username        String?
  bio             String?
  defaultLanguage String   @default("English (US)")
  defaultDuration String   @default("30 Seconds")
  defaultTone     String   @default("Professional")
  theme           String   @default("System")
  
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  SCRIPTING
  VOICING
  GENERATING
  COMPLETED
  FAILED
  PAUSED
  ARCHIVED
}

enum ProjectStep {
  IDEA
  SCRIPT
  VOICE
  VIDEO
}

enum VideoRatio {
  RATIO_16_9 @map("16:9")
  RATIO_9_16 @map("9:16")
  RATIO_1_1  @map("1:1")
}

enum GenerationType {
  SCRIPT
  VOICE
  VIDEO
}

enum GenerationStatus {
  PENDING
  RUNNING
  IN_PROGRESS
  COMPLETED
  FAILED
  PAUSED
  CANCELLED
}

enum Role {
  ADMIN
  SUPER_ADMIN
  ORG_ADMIN
  USER
  EDITOR
}

enum AccountStatus {
  ACTIVE
  PAUSED
  STOPPED
  DELETED
}

model Video {
  id                   String    @id @default(cuid())
  userId               String
  projectId            String
  title                String
  status               String    @default("COMPLETED")
  r2Key                String
  videoUrl             String    @db.Text
  fileSize             Int?
  duration             Float?
  thumbnailUrl         String?   @db.Text
  thumbnailKey         String?
  thumbnailGeneratedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  campaignId           String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments VideoAssignment[]
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  scheduledPosts ScheduledPost[]
  approvalRequests ApprovalRequest[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([organizationId])
}

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  platform     String    // "youtube", "linkedin", "facebook", "instagram", "twitter"
  email        String?
  channelName  String?
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?
  isDefault       Boolean   @default(false)
  channelId       String?
  subscriberCount String?
  zernioAccountId String?
  accountHandle   String?
  connectedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishedVideos PublishedVideo[]
  scheduledPosts  ScheduledPost[]

  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model PublishedVideo {
  id              String   @id @default(cuid())
  userId          String
  projectId       String
  socialAccountId String?
  platform        String   // "youtube", etc.
  externalVideoId String?  // ID on YouTube
  videoUrl        String?  @db.Text // link to watch on platform
  title           String
  status          String   // "Preparing Upload", "Uploading", "Processing", "Published", "Failed"
  postId          String?
  postUrl         String?  @db.Text
  errorMessage    String?  @db.Text
  publishedAt     DateTime?
  views           Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  createdAt       DateTime @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model EditorProfile {
  id           String             @id @default(cuid())
  userId       String             @unique
  editorKey    String             @unique
  displayName  String?
  bio          String?
  editorId     String?

  skills       String[]           @default([])
  availability EditorAvailability @default(AVAILABLE)
  createdAt    DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EditorUserConnection {
  id             String           @id @default(cuid())
  userId         String
  editorId       String
  connectionCode String
  status         ConnectionStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  connectedAt    DateTime         @default(now())
  disconnectedAt DateTime?

  // Relations
  user   User @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  editor User @relation("EditorConnections", fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([userId, editorId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId])
}

model ActivityLog {
  id           String   @id @default(cuid())
  actorId      String
  actorRole    String?
  targetUserId String?
  targetId     String?
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

model VideoAssignment {
  id             String           @id @default(cuid())
  videoId        String
  userId         String
  editorId       String
  status         AssignmentStatus @default(PENDING)
  progress       Int              @default(0)
  estimatedHours Int?
  notes          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?

  // Relations
  video  Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user   User          @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  editor User          @relation("EditorAssignments", fields: [editorId], references: [id], onDelete: Cascade)
  editedVideos EditedVideo[]

  @@index([userId])
  @@index([editorId])
}

model EditedVideo {
  id              String   @id @default(cuid())
  assignmentId    String
  originalVideoId String
  editedVideoUrl  String   @db.Text
  editedVideoKey  String
  thumbnailUrl    String?  @db.Text
  thumbnailKey    String?
  version         Int      @default(1)
  fileSize        Int?
  uploadedBy      String
  uploadedAt      DateTime @default(now())

  // Relations
  assignment VideoAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model CreditWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  scriptCredits  Int      @default(10)
  voiceCredits   Int      @default(10)
  videoCredits   Int      @default(5)
  publishCredits Int      @default(5)
  storageLimitGB Float    @default(10.0)
  storageUsedGB  Float    @default(0.0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
}

model CreditTransaction {
  id         String   @id @default(cuid())
  userId     String
  creditType String   // "SCRIPT" | "VOICE" | "VIDEO" | "PUBLISH"
  amount     Int
  action     String   // "ADDED" | "REMOVED" | "CONSUMED"
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ConnectionStatus {
  ACTIVE
  DISCONNECTED
  BLOCKED
  PENDING
  REJECTED
}

enum EditorAvailability {
  AVAILABLE
  BUSY
  OFFLINE
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  REVIEW
  REVISION_REQUESTED
  COMPLETED
  APPROVED
  REJECTED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  PAID
  PENDING
  FAILED
  VOID
}

model Organization {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  logo             String?
  primaryColor     String?            @default("#000000")
  secondaryColor   String?            @default("#ffffff")
  domain           String?            @unique
  status           OrganizationStatus @default(ACTIVE)
  subscriptionPlan SubscriptionPlan   @default(FREE)
  approvalRequired Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  users            User[]
  projects         Project[]
  videos           Video[]
  socialAccounts   SocialAccount[]
  creditWallets    CreditWallet[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  customDomains    CustomDomain[]
  invitations      TeamInvitation[]
  providerKeys     ProviderKey[]
  scheduledPosts   ScheduledPost[]
  campaigns        Campaign[]
  approvalRequests ApprovalRequest[]
  contentPlans     ContentPlan[]
  recurringTemplates RecurringTemplate[]
  automationRules  AutomationRule[]
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  plan           SubscriptionPlan
  status         SubscriptionStatus @default(ACTIVE)
  startDate      DateTime           @default(now())
  endDate        DateTime?
  monthlyCredits Int                @default(100)
  storageLimit   Float              @default(10.0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  amount         Float
  currency       String        @default("USD")
  status         InvoiceStatus @default(PENDING)
  invoiceNumber  String        @unique
  issuedAt       DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CustomDomain {
  id             String   @id @default(cuid())
  organizationId String
  domain         String   @unique
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TeamInvitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           Role
  token          String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ScheduledPost {
  id             String        @id @default(cuid())
  organizationId String
  videoId        String
  socialAccountId String?
  platform       String        // "youtube" | "linkedin" | "facebook" | "instagram" | "twitter"
  scheduledFor   DateTime
  status         String        // "PENDING" | "PENDING_APPROVAL" | "APPROVED" | "PUBLISHED" | "FAILED"
  publishedAt    DateTime?
  errorMessage   String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  video          Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  socialAccount  SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  campaignId     String?
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model Campaign {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  videos         Video[]
  scheduledPosts ScheduledPost[]
}

model ApprovalRequest {
  id             String        @id @default(cuid())
  organizationId String
  videoId        String
  userId         String        // Requested by
  status         String        // "PENDING" | "APPROVED" | "REJECTED" | "CHANGES_REQUESTED"
  requestedDate  DateTime      @default(now())
  feedback       String?       @db.Text
  actionedAt     DateTime?
  actionedById   String?

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  video          Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentPlan {
  id             String            @id @default(cuid())
  organizationId String
  niche          String
  targetAudience String
  frequency      String
  createdAt      DateTime          @default(now())

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          ContentPlanItem[]
}

model ContentPlanItem {
  id            String      @id @default(cuid())
  contentPlanId String
  topic         String
  hook          String      @db.Text
  scriptIdea    String      @db.Text
  publishingDate DateTime
  status        String      @default("PLANNED") // "PLANNED" | "GENERATED" | "SCHEDULED" | "PUBLISHED"
  videoId       String?

  contentPlan   ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
}

model RecurringTemplate {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  prompt         String        @db.Text
  frequency      String        // DAILY, WEEKLY, MONTHLY
  dayOfWeek      Int?          // 0-6
  dayOfMonth     Int?          // 1-31
  timeOfDay      String        // HH:MM
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id             String        @id @default(cuid())
  organizationId String
  triggerEvent   String
  actionType     String
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  type        CalendarEventType
  startDate   DateTime
  dueDate     DateTime
  priority    EventPriority     @default(MEDIUM)
  status      EventStatus       @default(PENDING)

  userId      String?
  user        User?             @relation("UserEvents", fields: [userId], references: [id], onDelete: Cascade)

  editorId    String?
  editor      User?             @relation("EditorEvents", fields: [editorId], references: [id], onDelete: Cascade)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([editorId])
}

enum CalendarEventType {
  MEETING
  TASK
  DEADLINE
  DELIVERY
  REVIEW
  ASSIGNMENT
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EventStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

